{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@yunwu/db": ["../../packages/db"],
      "@yunwu/auth": ["../../packages/auth"],
      "@yunwu/ui": ["../../packages/ui"],
      "@yunwu/shared": ["../../packages/shared"],
      "@yunwu/platform-core": ["../../packages/platform"],
      "@yunwu/platform-core/*": ["../../packages/platform/*"]
    }
  }
}
