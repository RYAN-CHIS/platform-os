generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@prisma/web-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── 七序（人生状态） ──
model Series {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String
  coverImage  String    @default("")
  heroText    String    @default("")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  longDesc    String?   @map("long_desc")
  shortDesc   String?   @map("short_desc")
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("series")
}

// ── 器物（作品） ──
model Product {
  id               Int              @id @default(autoincrement())
  sku              String           @unique
  name             String
  slug             String           @unique
  seriesId         Int              @map("series_id")
  series           Series           @relation(fields: [seriesId], references: [id])
  objectCategory   ObjectCategory   @default(BRACELET) @map("object_category")
  theme            String           @default("")
  story            String           @default("")
  materials        String           @default("")
  materialsRelation  ProductMaterial[]
  productTags        ProductTag[]
  costPrice        Float            @default(0)  @map("cost_price")
  salePrice        Float            @default(0)  @map("sale_price")
  coverImage       String           @default("") @map("cover_image")
  gallery          String           @default("[]")
  stock            Int              @default(0)
  status           String           @default("draft")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt     @map("updated_at")
  inspiration     String?         @map("inspiration")
  keywords        String?         @map("keywords")
  lifeStage       String?         @map("life_stage")
  suitableFor     String?         @map("suitable_for")
  // 器物履历 (V2.1)
  materialOrigin  String?         @map("material_origin")
  craftMethod     String?         @map("craft_method")
  completionDate  DateTime?       @map("completion_date")
  serialNumber    String?         @map("serial_number")
  creationStory   String?         @map("creation_story")
  emotionalState  String?         @map("emotional_state")
  // 时间性缓存 (V2.1)
  companionsCount Int             @default(0) @map("companions_count")
  remainingQuantity Int?          @map("remaining_quantity")

  @@index([seriesId])
  @@index([status])
  @@index([objectCategory])
  @@map("products")
}

// ── 器物分类 ──
enum ObjectCategory {
  BRACELET   // 珠串
  INCENSE    // 香器
  SEAL       // 印章
  CERAMIC    // 瓷器
  ENAMEL     // 珐琅
  SCHOLAR    // 文房
}

// ── 材料库 ──
model Material {
  id             Int       @id @default(autoincrement())
  name           String    @unique
  type           String    @default("")
  origin         String    @default("")
  description    String    @default("")
  image          String    @default("")
  alias          String?   @map("alias")
  features       String?   @map("features")
  history        String?   @map("history")
  relatedArticles String    @default("[]") @map("related_articles")
  productMaterials  ProductMaterial[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("materials")
}

// ── 作品-材料多对多关联 ──
model ProductMaterial {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  materialId Int      @map("material_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([productId, materialId])
  @@map("product_materials")
}

// ── 订单 ──
model Order {
  id          Int       @id @default(autoincrement())
  orderNo     String    @unique @map("order_no")
  productId   Int       @map("product_id")
  productName String    @default("") @map("product_name")
  quantity    Int       @default(1)
  amount      Float
  customerName String   @default("") @map("customer_name")
  phone       String    @default("")
  address     String    @default("")
  remark      String    @default("")
  status      String    @default("pending")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("orders")
}

// ── 品牌志（Journal） ──
model JournalPost {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  excerpt          String?
  content          String
  coverImage       String?         @map("cover_image")
  coverAlt         String?         @map("cover_alt")
  readingTime      Int?            @map("reading_time")
  category         JournalCategory
  status           PublishStatus   @default(DRAFT)
  seoTitle         String?         @map("seo_title")
  seoDescription   String?         @map("seo_description")
  publishedAt      DateTime?       @map("published_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  journalTags       JournalTag[]

  @@index([status, publishedAt])
  @@index([category])
  @@map("journal_posts")
}

// 品牌志分类：器物、材料、工艺、东海、创作、哲思
enum JournalCategory {
  OBJECT      // 器物
  MATERIAL    // 材料
  CRAFT       // 工艺
  DONGHAI     // 东海
  CREATION    // 创作
  PHILOSOPHY  // 哲思
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

// ── 联系表单线索 ──
model ContactLead {
  id               String   @id @default(cuid())
  name             String
  we_chat           String?  @map("we_chat")
  email            String?  @map("email")
  message          String?
  interestedCategory  String?  @map("interested_category")
  interestedSeries   String?  @map("interested_series")
  sourcePage        String?  @map("source_page")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("contact_leads")
}

