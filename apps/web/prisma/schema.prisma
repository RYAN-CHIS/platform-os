// ── 管理员角色 ──
enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  OPERATOR
}

// ── 媒体库分类 ──
enum MediaCategory {
  PRODUCT      // 作品
  BEADS        // 珠串
  SEAL         // 印章
  INCENSE      // 香器
  PORCELAIN   // 瓷器
  WOODWORK     // 木作
  OTHER_OBJ    // 其他器物
  MATERIAL     // 材料
  BRAND        // 品牌
  CRAFT        // 工艺
  ARTICLE      // 文章
}

// ── 标签类型 ──
enum TagType {
  SERIES       // 七序
  VALUE        // 价值
  MATERIAL     // 材料
  EMOTION      // 情绪
  SCENE        // 场景
  OBJECT       // 器物
}

// ── 管理员账号 ──
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  auditLogs    AuditLog[] @relation("AuditLogUser")

  @@map("admin_users")
}

// ── 审计日志 ──
model AuditLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        AdminUser @relation("AuditLogUser", fields: [userId], references: [id], onDelete: Cascade)
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── 媒体库 ──
model Media {
  id         String       @id @default(cuid())
  filename   String
  url        String
  category   MediaCategory
  altText    String?      @map("alt_text")
  size       Int
  mimeType   String       @map("mime_type")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@map("media")
}

// ── 页面内容块 ──
model PageContent {
  id          String   @id @default(cuid())
  pageKey     String   @map("page_key")
  sectionKey  String   @map("section_key")
  title       String   @default("")
  content     String   @default("")
  image       String?
  sortOrder   Int      @default(0) @map("sort_order")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([pageKey, sectionKey])
  @@map("page_contents")
}

// ── SEO 配置 ──
model SeoConfig {
  id          String   @id @default(cuid())
  pageKey     String   @unique @map("page_key")
  title       String
  description String
  ogImage     String?  @map("og_image")
  canonical   String?  @map("canonical")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("seo_configs")
}

// ── 站点设置 ──
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ── 标签 ──
model Tag {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  type        TagType
  createdAt   DateTime @default(now()) @map("created_at")
  productTags   ProductTag[]
  journalTags   JournalTag[]

  @@map("tags")
}

// ── 作品-标签多对多 ──
model ProductTag {
  id        String @id @default(cuid())
  productId Int    @map("product_id")
  tagId     String @map("tag_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@map("product_tags")
}

// ── 品牌志-标签多对多 ──
model JournalTag {
  id        String @id @default(cuid())
  journalId String @map("journal_id")
  tagId     String @map("tag_id")
  journal   JournalPost @relation(fields: [journalId], references: [id], onDelete: Cascade)
  tag       Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([journalId, tagId])
  @@map("journal_tags")
}
